# Скопируйте этот файл в .env.local и заполните значениями из вашего проекта Supabase
# (Project Settings -> API)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Только для серверного кода (вебхуки, скрипты). Никогда не публикуется в браузер.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Адрес сайта — используется в ссылках, которые Supabase шлёт в письмах (подтверждение email, восстановление пароля).
# Локально оставьте как есть; после деплоя на Vercel замените на реальный домен.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Ключ Яндекс.Карт (JavaScript API и HTTP Геокодер) — получить на developer.tech.yandex.ru.
# Без ключа карта на сайте не сломает страницу, просто покажет заглушку вместо себя.
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=
